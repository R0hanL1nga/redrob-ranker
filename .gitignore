# =============================================================================
# Redrob Ranker — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Dataset files (NEVER commit — too large and may be restricted)
# ---------------------------------------------------------------------------
data/candidates.jsonl
data/*.jsonl
data/*.json
!data/.gitkeep          # keep the empty data/ directory tracked

# ---------------------------------------------------------------------------
# Submission output (generated file — not source code)
# ---------------------------------------------------------------------------
submission.csv
*_submission.csv
ranking_run.log

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env

# ---------------------------------------------------------------------------
# IDE & OS
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Pytest / Coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.log

# ---------------------------------------------------------------------------
# Jupyter Notebooks (keep .ipynb but not checkpoints)
# ---------------------------------------------------------------------------
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Secrets
# ---------------------------------------------------------------------------
.env
.env.*
secrets.yaml
